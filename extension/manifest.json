{
  "manifest_version": 3,
  "name": "WebMCP Bridge",
  "version": "0.1.0",
  "description": "Bridge WebMCP tools to AI clients via MCP",
  "permissions": ["tabs", "scripting", "activeTab", "storage"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WebMCP Bridge"
  }
}
